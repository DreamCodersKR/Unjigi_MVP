# 운지기 환경변수 — 영일이가 카톡 DM으로 받은 값을 .env 두 곳에 직접 작성
#
# 사용법:
#   cp .env.example frontend/.env.local
#   cp .env.example backend/.env
#   각각 실제 값으로 교체

# ─────────────────────────────────────────────
# Frontend (frontend/.env.local로 복사)
# ─────────────────────────────────────────────

# Naver Cloud Platform — Maps API
# 발급: https://www.ncloud.com → Console → Application Services → Maps
VITE_NAVER_MAPS_CLIENT_ID=

# 백엔드 API URL (개발: localhost / 프로덕션: Railway 도메인)
VITE_API_BASE_URL=http://localhost:8000

# ─────────────────────────────────────────────
# Backend (backend/.env로 복사)
# ─────────────────────────────────────────────

# Naver Cloud Platform — Maps Secret (Geocoding 서버 호출용)
NAVER_MAPS_CLIENT_SECRET=

# Anthropic Claude API (운지기 워크스페이스 키)
# 발급: https://console.anthropic.com → API Keys
# 권장 모델: claude-haiku-4-5 (저렴 + 한국어 자연도)
ANTHROPIC_API_KEY=

# 기상청 단기예보 API (공공데이터포털)
# 발급: https://www.data.go.kr → 기상청_단기예보 조회서비스
KMA_API_KEY=
KMA_BASE_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0

# 공공데이터포털 (라운지·DTG 등 향후 활용)
DATA_GO_KR_KEY=

# ─────────────────────────────────────────────
# Common
# ─────────────────────────────────────────────
LOG_LEVEL=DEBUG
ENV=development
