# === 운지기 MVP — 환경변수 템플릿 ===
# .env.local / .env.test / .env.production 으로 복사해서 사용
# APP_ENV 값에 따라 자동 로딩됨 (기본값: local)

APP_ENV=local
DATABASE_URL=postgresql+asyncpg://unjigi:unjigi_local_pw@localhost:5433/unjigi_dev
# DIRECT_URL: Alembic 마이그레이션용 (Supabase Session pooler 5432 포트)
# 로컬에서는 DATABASE_URL과 동일. test/production에서는 포트만 다름 (6543→5432)
DIRECT_URL=postgresql+asyncpg://unjigi:unjigi_local_pw@localhost:5433/unjigi_dev

# 인증
USE_MOCK_AUTH=true
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# 외부 API
ANTHROPIC_API_KEY=
NAVER_MAPS_CLIENT_ID=
NAVER_MAPS_CLIENT_SECRET=
KMA_API_KEY=
DATA_GO_KR_KEY=
